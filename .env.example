# Token du bot (Developer Portal > Bot > Reset Token)
TOKEN=colle_ton_token_ici

# ID du serveur à protéger
GUILD_ID=123456789012345678

# TON ID Discord (seul à pouvoir utiliser %help)
OWNER_ID=

# Préfixe des commandes texte
PREFIX=%

# Code vanity à verrouiller en permanence (RECOMMANDÉ sur Railway)
LOCKED_VANITY=

# (Optionnel) Salon de logs des alertes
LOG_CHANNEL_ID=

# Sanction de l'auteur : derank | kick | ban | none
PUNISHMENT=derank

# (Optionnel) IDs autorisés à changer la vanity sans sanction (séparés par des virgules)
WHITELIST=
